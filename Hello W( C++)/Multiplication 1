#include <iostream>
using namespace std;

int main() {
    int number;

    // Ask user for a number
    cout << "Enter a number: ";
    cin >> number;

    // Use for loop from 1 to 10
    for (int i = 1; i <= 10; i++) {
        cout << number << " x " << i << " = " << number * i << endl;
    }

    return 0;
}
